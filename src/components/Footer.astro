---
import Separator from "./Separator.astro";
import { MailIcon } from "@lucide/astro";
---

<Separator />
<footer class="max-w-5xl mx-auto w-full border-x bg-diagonal-lines bg-fixed">
  <div class="grid grid-cols-2">
    <div class="flex flex-col border-r">
      <div class="flex bg-background">
        <a
          href="/"
          class="p-4 btn-interactive text-xl active:font-normal font-extrabold font-mono"
        >
          Ingo Wolf
        </a>
      </div>
      <div class="flex flex-row bg-background border-y">
        <a href="/" class="p-4 aspect-square btn-interactive border-r">
          <MailIcon class="size-4" />
        </a>
      </div>
    </div>
  </div>
</footer>
<div class="border-t w-full"></div>
<div class="max-w-5xl mx-auto w-full border-x h-4"></div>
