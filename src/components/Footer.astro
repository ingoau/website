---
import { NAVBAR_ITEMS, OTHER_PAGES } from "@/lib/constants";
import Separator from "./Separator.astro";
import ChevronLeftIcon from "~icons/material-symbols/chevron-left-rounded";
import ChevronRightIcon from "~icons/material-symbols/chevron-right-rounded";
import Buttons from "./Buttons.astro";

const profiles = [
  {
    text: "Email",
    href: "mailto:me@ingo.au",
  },
  {
    text: "Signal",
    href: "",
  },
  {
    text: "GitHub",
    href: "https://github.com/ingoau",
  },
];

const webrings = [
  {
    name: "ultrafastparrot",
    url: "https://ultrafastparrot.net",
    next: "https://ultrafastparrot.net/next/ingo",
    prev: "https://ultrafastparrot.net/prev/ingo",
  },
  {
    name: "catppuccin",
    url: "https://ctp-webr.ing/",
    next: "https://ctp-webr.ing/ingo/next",
    prev: "https://ctp-webr.ing/ingo/prev",
  },
  {
    name: "page ring",
    onClick:
      "if (window.pagering) { window.pagering.open(); window.pagering.open(); } else { location.href = 'https://pagering.gideon.sh/'; }",
    next: "https://pagering.gideon.sh/to/ingo/next",
    prev: "https://pagering.gideon.sh/to/ingo/prev",
  },
];
---

<div class="w-full px-4 grow flex flex-col border-b">
  <Separator class="grow" />
  <footer class="max-w-5xl mx-auto w-full border-l bg-diagonal-lines bg-fixed">
    <div class="md:grid md:grid-cols-14">
      <div class="flex flex-col border-r col-span-6 pb-10">
        <div class="flex bg-background">
          <a
            class="p-4 btn-interactive text-xl active:font-normal font-extrabold font-mono w-full"
            href="/"
          >
            Ingo Wolf
          </a>
        </div>
        <div class="border-y w-full">
          <div class="flex flex-row bg-background w-fit">
            {
              profiles.map((link) => (
                <a class="px-4 py-2 btn-interactive border-r" href="/">
                  {link.text}
                </a>
              ))
            }
          </div>
        </div>
      </div>
      <div class="col-span-4 hidden md:block"></div>
      <div class="col-span-4 md:border-l flex flex-col border-t md:border-t-0">
        <div class="p-2 border-b font-mono border-r bg-background">Pages</div>
        <div class="bg-card w-full grid grid-cols-2">
          {
            [...NAVBAR_ITEMS, ...OTHER_PAGES].map((link) => (
              <div class="border-b border-r flex flex-col bg-background">
                <a class="p-2 btn-interactive text-sm" href={link.url}>
                  {link.label}
                </a>
              </div>
            ))
          }
          {
            [...NAVBAR_ITEMS, ...OTHER_PAGES].length % 2 !== 0 && (
              <div class="border-r border-b bg-striped-gradient" />
            )
          }
        </div>
        <div class="grow min-h-10 border-r"></div>
      </div>
    </div>
    <div
      class="flex flex-col-reverse md:flex-row bg-diagonal-lines bg-fixed border-t md:items-end border-b"
    >
      <div
        class="border-t border-r py-2 px-4 font-mono bg-background h-fit text-center"
      >
        This website is
        <a href="https://github.com/ingoau/website" target="_blank">
          open source
        </a>
      </div>
      <div class="grow"></div>
      <div class="flex flex-col bg-background">
        <div class="p-2 font-mono border-r md:border-l">Webrings</div>
        {
          webrings.map((webring) => (
            <div class="flex flex-row w-full">
              <a
                class="btn-interactive p-3 aspect-square border-r md:border-l border-t"
                href={webring.prev}
              >
                <span class="sr-only">Previous</span>
                <ChevronLeftIcon class="size-4" />
              </a>
              <a
                class="btn-interactive px-6 text-sm font-mono grow flex items-center justify-center border-t cursor-pointer"
                href={webring.url}
                onclick={webring.onClick}
              >
                {webring.name}
              </a>
              <a
                class="btn-interactive p-3 aspect-square border-x border-t"
                href={webring.next}
              >
                <span class="sr-only">Previous</span>
                <ChevronRightIcon class="size-4" />
              </a>
            </div>
          ))
        }
      </div>
    </div>
    <div class="w-full border-r">
      <div class="mx-auto w-fit">
        <Buttons />
      </div>
    </div>
  </footer>
</div>
<div class="w-full px-4">
  <div class="max-w-5xl mx-auto w-full border-x h-4"></div>
</div>
