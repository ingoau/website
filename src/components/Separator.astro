---
import { cn } from "@/lib/utils";

const {
  class: className,
  separatorType = "lines",
}: { class?: string; separatorType?: "lines" | "striped" } = Astro.props;
---

<div
  class:list={cn(
    "mx-auto h-10 w-full max-w-5xl border-x border-b",
    separatorType === "lines" && "bg-diagonal-lines",
    separatorType === "striped" && "bg-striped-gradient",
    className,
  )}
>
</div>
