---
import type { CodeLanguage } from "astro";
import { Code } from "astro:components";

interface Props {
  node: {
    _key: string;
    _type: string;
    code: string;
    language: string;
  };
}
const { node } = Astro.props;
---

<Code
  code={node.code}
  lang={node.language as CodeLanguage}
  wrap
  theme="catppuccin-mocha"
/>
