---
import { urlFor } from "@/lib/sanity/queries";
import { Image as ImageComponent } from "astro:assets";

export interface Props {
  alt: string;
  asset: {
    _ref: string;
  };
}

const { alt, asset } = Astro.props;

const image = urlFor(asset._ref);
const src = image.url();
---

<ImageComponent src={src} alt={alt} inferSize={true} />
