---
import { Menu, Search } from "@lucide/astro";
---

<div class="border-l w-fit">
  <button
    class="menu-item btn-interactive px-6 md:px-8 cursor-pointer gap-2"
    id="search-button"
  >
    <span class="hidden md:block"> More </span>
    <Menu class="size-4 md:hidden" />
    <span class="sr-only">Menu</span>
  </button>
</div>

<script>
  import { isMenuOpen } from "@/lib/state";

  document.getElementById("search-button")?.addEventListener("click", () => {
    isMenuOpen.set(true);
  });

  document.addEventListener("keydown", (e) => {
    if (
      // Mod pressed
      (e.metaKey || e.ctrlKey) &&
      // K pressed
      e.key === "k" &&
      // Not focused on an input or textarea
      !document.activeElement?.matches("input, textarea")
    ) {
      e.preventDefault();
      isMenuOpen.set(true);
      return false;
    }
  });
</script>
