---
const things = [
  {
    title: "Web",
    description:
      "I have built many websites for friends and community things, such as Hack Club YSWSes. I also build web apps to solve my problems, and for fun.",
  },
  {
    title: "Infrastructure",
    description:
      "I run and maintain about 40 Docker containers in my homelab which are behind Traefik. I have also set up SSO to everything with authentik.",
  },
  {
    title: "Networking",
    description:
      "I have set up VLANs in my home network for security and organization, and force my family to use username/password auth.",
  },
];
---

<div
  class="w-full mx-auto grid grid-cols-1 sm:grid-cols-3 max-w-5xl border-b sm:py-8 gap-6 sm:px-8 bg-diagonal-lines sm:border-x"
>
  {
    things.map((thing) => (
      <div class="hover-card">
        <h2 class="text-2xl text-primary">{thing.title}</h2>
        <p>{thing.description}</p>
      </div>
    ))
  }
</div>

<style>
  @reference "../../styles/global.css";
  .hover-card {
    @apply bg-background p-4 duration-100 ease-out outline outline-dashed outline-border;
    transition:
      transform 0.2s ease-out,
      background-color 0.2s ease-out,
      box-shadow 0.2s ease-out;
  }
  .hover-card:hover {
    transform: scale(1.05) rotate(0.5deg);
    @apply shadow-2xl bg-card z-50;
    transition:
      transform 0.2s ease-out,
      background-color 0.2s ease-out,
      box-shadow 0.2s ease-out;
  }
</style>
