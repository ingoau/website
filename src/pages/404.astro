---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404">
  <div
    class="w-full max-w-5xl mx-auto border-x border-b py-20 flex flex-col items-center justify-center gap-8 bg-diagonal-lines bg-fixed"
  >
    <div class="flex flex-col items-center">
      <h1 class="text-9xl font-mono">404</h1>
      <p class="text-2xl">Page not found</p>
    </div>
    <div
      class="w-full border-y flex justify-center items-stretch"
    >
      <div class="border-x flex bg-background">
        <a href="/" class="cursor-pointer px-8 py-4 btn-interactive">Home</a>
      </div>
    </div>
  </div>
</Layout>
