---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404">
  <div
    class="bg-diagonal-lines mx-auto flex w-full max-w-5xl flex-col items-center justify-center gap-8 border-x border-b bg-fixed py-20"
  >
    <div class="flex flex-col items-center">
      <h1 class="font-mono text-9xl">404</h1>
      <p class="text-2xl">Page not found</p>
    </div>
    <div class="flex w-full items-stretch justify-center border-y">
      <div class="bg-background flex border-x">
        <a class="btn-interactive cursor-pointer px-8 py-4" href="/">Home</a>
      </div>
    </div>
  </div>
</Layout>
