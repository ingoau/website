---
import Layout from "@/layouts/Layout.astro";
import { postQuery, postsQuery } from "@/lib/sanity/queries";
import type { PostsQueryResult, PostQueryResult } from "sanity.types";
import { sanityClient } from "sanity:client";

const { slug } = Astro.params;

export const getStaticPaths = async () => {
  const posts = (await sanityClient.fetch(postsQuery)) as PostsQueryResult;
  return posts.map((post) => ({
    params: { slug: post.slug?.current ?? "" },
  }));
};

const post: PostQueryResult = await sanityClient.fetch(postQuery, { slug });

if (!post) {
  return new Response(null, { status: 404 });
}
---

<Layout title={post.title}>
  {post.title}
</Layout>
