---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Font } from "astro:assets";
import Search from "../components/Search.tsx";
import Pagering from "@/components/Pagering.astro";
import Posthog from "@/components/Posthog.astro";
import { Schema } from "astro-seo-schema";

const { title, description }: { title?: string; description?: string } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width" name="viewport" />
    <link href="/icons/rounded.svg" rel="icon" type="image/svg+xml" />
    <link href="/favicon.ico" rel="icon" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta content={Astro.generator} name="generator" />

    <!-- Seo tags -->
    {description && <meta content={description} name="description" />}
    <meta
      property="og:title"
      content={(title ?? "Ingo's Site") + (title && " | Ingo's Site")}
    />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Ingo Wolf",
        url: "https://ingo.au",
        email: "me@ingo.au",
        description: "Web developer from Canberra, Australia",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Canberra",
          addressRegion: "ACT",
          addressCountry: "AU",
        },
        sameAs: [
          "https://github.com/ingoau",
          "https://gitlab.com/ingowolf",
          "https://en.pronouns.page/@ingowolf",
          "https://www.linkedin.com/in/ingoau/",
          "https://monkeytype.com/profile/ingow",
          "https://last.fm/user/ingoau",
          "https://x.com/IngoWolfAU",
        ],
        knowsAbout: [
          "Web development",
          "TypeScript",
          "React",
          "Astro",
          "Svelte",
          "Infrastructure",
          "Homelab",
          "Networking",
        ],
        height: "190 cm",
        pronouns: "he/they",
      }}
    />

    <Font cssVariable="--font-geist-mono" preload transition:persist />
    <Font cssVariable="--font-outfit" preload transition:persist />
    <title>{title ?? "Ingo's Site"} {title && "| Ingo's Site"}</title>
    <Posthog />
  </head>
  <body class="flex min-h-screen flex-col">
    <Navbar />
    <Search client:idle />
    <div class="w-full px-4">
      <main class="bg-background mx-auto w-full max-w-5xl">
        <slot />
      </main>
    </div>
    <Footer />
    <Pagering />
  </body>
</html>
