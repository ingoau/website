---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Font } from "astro:assets";
import Search from "../components/Search.tsx";
import { ClientRouter } from "astro:transitions";
import Pagering from "@/components/Pagering.astro";

const { title }: { title?: string } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/icons/rounded.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="view-transition" content="same-origin" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-geist-mono" preload transition:persist />
    <Font cssVariable="--font-outfit" preload transition:persist />
    <!-- <ClientRouter /> -->
    <title>{title ?? "Ingo's Site"} {title && "| Ingo's Site"}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <Navbar />
    <Search client:idle />
    <div class="w-full px-4">
      <main class="max-w-5xl mx-auto w-full bg-background">
        <slot />
      </main>
    </div>
    <Footer />
    <Pagering />
  </body>
</html>
